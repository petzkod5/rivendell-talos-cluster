{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "labels": [
    "dependencies"
  ],
  "prHourlyLimit": 4,
  "prConcurrentLimit": 6,
  "minimumReleaseAge": "3 days",
  "enabledManagers": [
    "kubernetes",
    "helm-values",
    "helmfile",
    "custom.regex"
  ],
  "kubernetes": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/.+\\.ya?ml$/"
    ]
  },
  "helm-values": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/values/.+\\.ya?ml$/"
    ]
  },
  "helmfile": {
    "managerFilePatterns": [
      "/(^|/)kubernetes/helmfile\\.ya?ml$/"
    ]
  },
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update Helm chart versions declared in Argo CD Applications",
      "managerFilePatterns": [
        "/(^|/)kubernetes/apps/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "repoURL:\\s*(?<registryUrl>https://[^\\n]+)\\s*\\n\\s*chart:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "helm"
    },
    {
      "customType": "regex",
      "description": "Update OCI Helm chart versions declared in Argo CD Applications",
      "managerFilePatterns": [
        "/(^|/)kubernetes/apps/.+\\.ya?ml$/"
      ],
      "matchStrings": [
        "repoURL:\\s*(?<registryUrl>ghcr\\.io/[^\\n]+)\\s*\\n\\s*chart:\\s*(?<depName>[^\\s]+)\\s*\\n\\s*targetRevision:\\s*(?<currentValue>[^\\s]+)"
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "{{{registryUrl}}}/{{{depName}}}"
    }
  ],
  "packageRules": [
    {
      "description": "Require manual approval for major infrastructure updates",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Automerge digest pin refreshes after CI passes",
      "matchUpdateTypes": [
        "digest"
      ],
      "automerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Do not automerge Helm chart updates until the workflow has proven stable",
      "matchDatasources": [
        "helm"
      ],
      "automerge": false
    },
    {
      "description": "Treat the OCI-hosted megascope chart like other Helm charts (no automerge)",
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "ghcr.io/petzkod5/charts/megascope"
      ],
      "automerge": false
    },
    {
      "description": "Group Kubernetes manifest image updates",
      "matchManagers": [
        "kubernetes"
      ],
      "groupName": "kubernetes-images"
    }
  ]
}
